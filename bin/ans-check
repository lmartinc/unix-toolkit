#!/usr/bin/env bash

###############################################################################
#
# Name        : ans-check
#
# Description : Validate an Ansible project
#
###############################################################################

source "${HOME}/.unix-toolkit/lib/common.sh"

PROJECT="$(basename "$PWD")"

CHECKS=0
FAILURES=0

INSTALLED_COLLECTIONS=""

###############################################################################
# Usage
###############################################################################

usage()
{
cat <<EOF

Usage:

    ans-check

Description:

    Validate the current Ansible project.

EOF
}

###############################################################################
# Banner
###############################################################################

show_banner()
{
    echo
    echo "============================================================"
    echo "                 Unix Toolkit - ans-check"
    echo "============================================================"
    echo
    echo "Project   : ${PROJECT}"
    echo "Location  : ${PWD}"
}

###############################################################################
# Load installed collections
###############################################################################

load_installed_collections()
{
    INSTALLED_COLLECTIONS="$(
        ansible-galaxy collection list |
        awk '
            /^[A-Za-z0-9_.-]+/ {
                print $1, $2
            }
        '
    )"
}

###############################################################################
# Read required collections
###############################################################################

get_required_collections()
{
    awk '
        /name:/ {
            print $2
        }
    ' requirements.yml
}

###############################################################################
# Check one collection
###############################################################################

check_collection()
{
    local collection="$1"
    local installed
    local version

    installed="$(
        grep "^${collection}[[:space:]]" <<< "${INSTALLED_COLLECTIONS}"
    )"

    if [[ -n "${installed}" ]]
    then
        version="$(awk '{print $2}' <<< "${installed}")"

        log_status true "${collection}" "${version}"

        return 0
    fi

    log_status false "${collection}"

    return 1
}

###############################################################################
# Check project structure
###############################################################################

check_project()
{
    section "Project Structure"

    ((CHECKS++))
    check_file ansible.cfg || ((FAILURES++))

    ((CHECKS++))
    check_file requirements.yml || ((FAILURES++))

    ((CHECKS++))
    check_directory inventory || ((FAILURES++))

    ((CHECKS++))
    check_directory playbooks || ((FAILURES++))

    ((CHECKS++))
    check_directory roles || ((FAILURES++))

    ((CHECKS++))
    check_directory group_vars || ((FAILURES++))

    ((CHECKS++))
    check_directory host_vars || ((FAILURES++))
}

###############################################################################
# Check required commands
###############################################################################

check_commands()
{
    section "Required Commands"

    ((CHECKS++))
    check_command ansible-playbook || ((FAILURES++))

    ((CHECKS++))
    check_command ansible-galaxy || ((FAILURES++))

    ((CHECKS++))
    check_command ansible-lint || ((FAILURES++))

    ((CHECKS++))
    check_command yamllint || ((FAILURES++))
}

###############################################################################
# Check collections
###############################################################################

check_collections()
{
    section "Collections"

    load_installed_collections

    while read -r collection
    do
        [[ -z "${collection}" ]] && continue

        ((CHECKS++))

        check_collection "${collection}" || ((FAILURES++))

    done < <(get_required_collections)
}

###############################################################################
# Summary
###############################################################################

show_summary()
{
    section "Summary"

    echo "Checks completed : ${CHECKS}"
    echo "Failures         : ${FAILURES}"
    echo

    if (( FAILURES == 0 ))
    then
        log_ok "Project status : HEALTHY"
    else
        log_error "Project status : FAILED"
        exit 1
    fi

    separator
}

###############################################################################
# Main
###############################################################################

main()
{
    case "${1:-}" in
        -h|--help)
            usage
            exit 0
            ;;
    esac

    show_banner

    check_project

    check_commands

    check_collections

    show_summary
}

main "$@"