#!/usr/bin/env bash

###############################################################################
#
# Name        : mkscript
#
# Description : Create a new shell script from the Unix Toolkit template
#
###############################################################################

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOOLKIT_HOME="${HOME}/.unix-toolkit"

source "${TOOLKIT_HOME}/lib/common.sh"
###############################################################################
# Usage
###############################################################################

usage()
{
    cat <<EOF

Usage:
    mkscript <script-name>

Example:
    mkscript backup_oracle

Creates a new shell script using the Unix Toolkit template.

EOF
}

###############################################################################
# Main
###############################################################################

main()
{
    case "${1:-}" in
        -h|--help)
            usage
            exit 0
            ;;
    esac

    if [[ $# -ne 1 ]]
    then
        usage
        exit 1
    fi

    require_command sed

    local SCRIPT_NAME="$1"
    local TEMPLATE_DIR="${TOOLKIT_ROOT}/templates"
    local TEMPLATE="${TEMPLATE_DIR}/script.sh"

    if [[ ! -f "${TEMPLATE}" ]]
    then
        log_error "Template not found:"
        echo "    ${TEMPLATE}"
        exit 1
    fi

    if [[ -e "${SCRIPT_NAME}" ]]
    then
        log_error "File already exists:"
        echo "    ${SCRIPT_NAME}"
        exit 1
    fi

    cp "${TEMPLATE}" "${SCRIPT_NAME}"

    sed -i \
        -e "s/__SCRIPT_NAME__/$(basename "${SCRIPT_NAME}")/g" \
        -e "s/__DATE__/$(date +%Y-%m-%d)/g" \
        "${SCRIPT_NAME}"

    chmod 755 "${SCRIPT_NAME}"

    log_ok "Created script"

    if command_exists realpath
    then
        echo
        echo "    $(realpath "${SCRIPT_NAME}")"
    else
        echo
        echo "    $(pwd)/${SCRIPT_NAME}"
    fi

    echo
    echo "Next step:"
    echo "    Edit the Description section before using the script."
    echo
}

main "$@"
