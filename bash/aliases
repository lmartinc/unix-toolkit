#
# Unix Toolkit Aliases
#

# Navigation
alias ..='cd ..'
alias ...='cd ../..'

# Listing
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'

# Safety
alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'

# Editors
alias vi='vim'

# Clear
alias cls='clear'


# Git
alias gs='git status'
alias gl='git log --oneline --graph --decorate'
alias gp='git pull'
alias gps='git push'

# Ansible
alias ap='ansible-playbook'
alias ai='ansible-inventory'
